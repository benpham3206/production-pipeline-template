# ============================================================================
# Production Pipeline — .gitignore
# Language-agnostic patterns for any technology stack
# ============================================================================

# Environment
.env
.env.local
.env.*.local
.env.production

# ---- JavaScript / TypeScript ----
node_modules/
dist/
build/
coverage/
*.tsbuildinfo
.next/
.nuxt/
.cache/

# ---- Python ----
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
.venv/
venv/
.mypy_cache/
.ruff_cache/

# ---- Go ----
vendor/

# ---- Rust ----
target/

# ---- Java / Kotlin ----
*.jar
*.class
*.war
.gradle/

# ---- Flutter / Dart ----
.dart_tool/
.packages

# ---- General build outputs ----
*.log
logs/

# ---- OS / Editor ----
.DS_Store
.vscode/
.idea/
*.swp
*.swo
Thumbs.db

# ---- Secrets (never commit) ----
*.key
*.pem
secrets/

# ---- Data ----
.data/
*.sqlite
*.db

# ---- Temporary ----
tmp/
temp/
.cache/

# ---- Agent local state ----
.kimi/

# ---- Playwright MCP temp files ----
.playwright-mcp/

# ---- Project workspaces built from this template ----
enterprise-pipeline/

# ---- Security assessments (local only) ----
redteam/
redteam2/
redteam3/
